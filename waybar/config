  "layer": "top",
  "position": "top",
  "height": 36,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["custom/volume", "custom/brightness", "network", "battery", "tray"],

  "clock": {
     "format": "{:%H:%M}"
  },

  "network": {
    "format-wifi": "{icon}",
    "format-ethernet": "ůįąÄ",
