{
  "layer": "top",
  "position": "top",
  "height": 36,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": [
    "pulseaudio",
    "network",
    "cpu",
    "memory",
    "battery"
  ],

  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate"
  },

  "clock": {
    "format": "  {:%H:%M}",
    "tooltip-format": "{:%A, %B %d}"
  },

  "cpu": {
    "format": "  {usage}%"
  },

  "memory": {
    "format": "  {}%"
  },

  "network": {
    "format-wifi": "  {signalStrength}%",
    "format-ethernet": "󰈀  Connected",
    "tooltip-format": "{ipaddr}"
  },

  "battery": {
    "format": "  {capacity}%",
    "format-charging": " {capacity}%"
  },

  "pulseaudio": {
    "format": "  {volume}%",
    "format-muted": "  muted"
  }
}
